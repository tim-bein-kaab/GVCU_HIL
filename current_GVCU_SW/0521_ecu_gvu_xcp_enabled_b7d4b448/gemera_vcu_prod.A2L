    /begin CHARACTERISTIC CCluFillTime_Map "Map for clutch fill time For all clutches Based on a curve fit I did on the old lookup table Result of curve fit: filltime(oiltemp) = 3800ms / (oiltemp + 19 deg C) + 10ms This means: At  1 deg C the fastfill time is 200ms ((3800/20 + 10) At 21 deg C the fastfill time is 105ms ((3800/40 + 10) At 81 deg C the fastfill time is  48ms ((3800/100 + 10) The function filltime vs oiltemp is likely different in each clutch And will likely change over the lifetime of the oil because the viscosity of the oil changes when the length of the polymer chains in the oil gets shorter and shorter when sheared apart during use 1B uses this formula: filltime(oiltemp) = 3500ms / (oiltemp + 19 deg C) + 10ms 1C uses this formula: filltime(oiltemp) = 3000ms / (oiltemp + 19 deg C) + 10ms"
      MAP 1073873912 __SWord_Value 0 tMillisecond_S16 0 3600000
      EXTENDED_LIMITS 0 3600000
      STEP_SIZE 1
      FORMAT "%.3"
      /begin AXIS_DESCR
        COM_AXIS NO_INPUT_QUANTITY tDegree_10_S16 20 0 0
        AXIS_PTS_REF CCluFillTime_XSP
      /end AXIS_DESCR
      /begin AXIS_DESCR
        FIX_AXIS NO_INPUT_QUANTITY NO_COMPU_METHOD 4 0 3
        FIX_AXIS_PAR_DIST 0 1 4
      /end AXIS_DESCR
      SYMBOL_LINK "CCluFillTime_Map" 0
    /end CHARACTERISTIC

    /begin AXIS_PTS CCluFillTime_XSP "XSP for clutch fill time (horisontal axis) Temperature points choosen to get a smooth transition between fastfill time deltas"
      1073873872 NO_INPUT_QUANTITY __SWord_Axis 0 tDegree_10_S16 20 -720.0 720.0
      EXTENDED_LIMITS -720.0 720.0
      STEP_SIZE 1
      FORMAT "%.1"
      SYMBOL_LINK "CCluFillTime_XSP" 0
    /end AXIS_PTS

