    /begin MOD_PAR ""
      SUPPLIER "Koenigsegg Automotive AB"
      ECU "GVCU"
      CPU_TYPE "MPC5777C"
      ADDR_EPK 0x40037BA4
      EPK "7cc1014e"
    /end MOD_PAR

    /begin CHARACTERISTIC flash_name ""
      ASCII 0xA00000 __UByte_Value 0 NO_COMPU_METHOD 0 255
      READ_ONLY
      NUMBER 4
    /end CHARACTERISTIC

    /begin MEASUREMENT flash_csum1 ""
      ULONG NO_COMPU_METHOD 0 0 0 0
      DISPLAY_IDENTIFIER flash_csum1
      ECU_ADDRESS 0xA00008
