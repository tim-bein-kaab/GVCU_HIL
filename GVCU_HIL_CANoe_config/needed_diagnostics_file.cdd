<ENUMRECORDITEMTMPL id='_0000020D2D75B830' oid='7F7058F9F955441eBE2F49F6F89B532E' temploid='{2C1F7058-4E16-4015-ACD4-2790A0E08C37}' mayBeDup='1' conv='req' v='5' sort='id'>
<NAME>
<TUV xml:lang='en-US'>Corrective action</TUV>
</NAME>
<QUAL>CorrectiveAction</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Replace ECU</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Check wiring connector</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>Check wiring</TUV>
</ETAG>
<ETAG v='3'>
