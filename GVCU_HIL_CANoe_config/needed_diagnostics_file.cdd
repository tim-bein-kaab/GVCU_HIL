<UNSDEF id='_0000020D0415C830' oid='5F8CB1AFD7794625B5738BC52CBDF4CA' temploid='4E50598D7EA34ad0907B94747FC31667' attrcatref='_0000020D2473C2E0' usage='sys' v='1792' df='hex'>
<NAME>
<TUV xml:lang='en-US'>Request CAN-ID</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The request CAN identifier for physical requests. The hex value not only describes the identifier but also the priority of the message. The higher the number, the lower the priority. </TUV>
</DESC>
<QUAL>CAN.ReqCanId</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D0415C030' oid='657C6378E57A4017B224C4166AB059C8' temploid='8F1A928D8071442b8A555654C2A03325' attrcatref='_0000020D2473C2E0' usage='sys' v='1536' df='hex'>
<NAME>
<TUV xml:lang='en-US'>Response CAN-ID</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The response CAN identifier for physical responses.The response for functional requests is sent via the physical path.</TUV>
</DESC>
<QUAL>CAN.ResCanId</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D24931070' oid='4A384A69E72845b6B597DA59493581E3' temploid='D61D6570A2364e2eB940FC451F1217B9' attrcatref='_0000020D2473C2E0' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>Functional Addressing Scheme</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Addressing Scheme used for functional requests.</TUV>
</DESC>
<QUAL>CAN.AddrSchemeFunc</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Normal</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D24930E80' oid='32F701FF06204b90BD4BE4006226E75F' temploid='4DA67705CCAE4edd9A4EAADA46586003' attrcatref='_0000020D2473C2E0' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>Functional CAN-ID Type</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>CAN-ID Type used for functional request</TUV>
</DESC>
<QUAL>CAN.CanIdTypeFunc</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>11-Bit</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>29-Bit</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D0415D830' oid='CAFF3434B1944a9197B365C38ABDA9A4' temploid='DD6D93D8D676436fA860209E9F5AE639' attrcatref='_0000020D2473C2E0' usage='sys' v='1872' df='hex'>
<NAME>
<TUV xml:lang='en-US'>Functional Request CAN-ID</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The request CAN identifier for functional requests.</TUV>
</DESC>
<QUAL>CAN.ReqCanIdFunc</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D0415CE30' oid='ED3C971909F6415686170E9C820C3A52' temploid='AAA2C8DCAD0F4d5b9FECEAF3BAFA5517' attrcatref='_0000020D2473C2E0' usage='sys' v='1920' df='hex'>
<NAME>
<TUV xml:lang='en-US'>UUDT Response CAN-ID</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>UUDT Response CAN-ID used for multiple responses and/or periodic responses.</TUV>
</DESC>
<QUAL>CAN.UudtResCanId</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D24931830' oid='B06E7A397FAF4234B776798330A8FF3C' temploid='55F798A69E4D496e82365EC2BB8057C2' attrcatref='_0000020D2473C2E0' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>UUDT CAN-ID Type</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Received CAN Format for CAN ID without segmentation (Segment Type Bit must = 0)</TUV>
</DESC>
<QUAL>CAN.UudtCanIdType</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>11-Bit</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>29-Bit</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D0415C430' oid='60B99074450C4433839BC4A3B4F91EB4' temploid='236A22BB7ED34b99B96A150778D7B52A' attrcatref='_0000020D2473BF20' usage='sys' v='150' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Timeout for the client to wait after the successful transmission of a request message for the start of incoming response messages. In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>CAN.P2Client</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D0415BC30' oid='A1D281A919D74d8eA86F567970295A24' temploid='17F5085A5AAD46bd8BD8A50BE2A50334' attrcatref='_0000020D2473BF20' usage='sys' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Performance requirement for the server to start with the response message after the reception of a request message. In UDS this is the timeout for the default session.The tester will also require the P2Server timeout, since in UDS service "DiagnosticSessionControl"returns the P2Server and P2*Server timeouts – the tester has to calculate the offset manually and has to add it to the returned P2Server and P2*Server timeouts.</TUV>
</DESC>
<QUAL>CAN.P2Server</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D0415CA30' oid='09901EEE5F4C41938501900CA4D91582' temploid='981A47637F6A49318C86FFC3CDC7B36E' attrcatref='_0000020D2473BF20' usage='sys' v='2000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2*Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enhanced timeout for the client to wait after the reception of a negative response message with response code 78 hex for the start of incoming response messages. In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>CAN.P2ExClient</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D0415D030' oid='87B94C7CC08547ed9BD08945ADEFADE3' temploid='9C4D6D08A311402e86A050A6D6E57408' attrcatref='_0000020D2473BF20' usage='sys' v='1950' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2*Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Performance requirement for the server to start with the response message after the transmission of a negative response message with response code 78 hex (enhanced response timing). In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>CAN.P2ExServer</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D5220' oid='DF9D9B3442904b2eA72AEF168634A043' temploid='66161D73836B4a5cB03605A5800B0C85' attrcatref='_0000020D2473BF20' usage='sys' v='4000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>S3Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time between functionally addressed Tester Present request messages transmitted by the client to keep a diagnostic session other than the defaultSession active in multiple servers (functional communication) or maximum time between physically transmitted request messages to a single server (physical communication).</TUV>
</DESC>
<QUAL>CAN.S3Client</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D4A20' oid='965902C8AE4E4c1eBCFC787A3DA6F62E' temploid='8A277D4CB181480a989F32CFDAAE68AB' attrcatref='_0000020D2473BF20' usage='sys' v='5000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>S3Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for the server to keep a diagnostic session other than the defaultSession active while not receiving any diagnostic request message</TUV>
</DESC>
<QUAL>CAN.S3Server</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D7E20' oid='2877AEFADA2A4843BE973696C2968CA5' temploid='1A9C386131B14e029D02B00AE733E3A4' attrcatref='_0000020D2473BF20' usage='sys' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P3ClientPhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Minimum time for the client to wait after the successful transmission of a physically addressed request message (indicated via N_USData.con) with no response required before it can transmit the next physically addressed request message.
Minimum value = P2Server</TUV>
</DESC>
<QUAL>CAN.P3ClientPhys</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D7820' oid='49E1C35AA678448e8080914FC039E367' temploid='22AABA5DEC33435585551D9B4D67065A' attrcatref='_0000020D2473C2E0' usage='sys' v='15872' df='hex'>
<NAME>
<TUV xml:lang='en-US'>TesterPresentPhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Defines the TesterPresent message for physically addressed requests used to keep a diagnostic session active.</TUV>
</DESC>
<QUAL>CAN.TesterPresentPhys</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D7A20' oid='12602199FA924477BA7BB4AD4C70806F' temploid='2573FACA63C94dcf9C065B5D01369B5D' attrcatref='_0000020D2473BF20' usage='sys' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P3ClientFunc</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Minimum time for the client to wait after the successful transmission of a functionally addressed request message (indicated via N_USData.con) before it can transmit the next functionally addressed request message in case no response is required or the requested data is only supported by a subset of the functionally addressed servers.
Minimum value = P2Server.</TUV>
</DESC>
<QUAL>CAN.P3ClientFunc</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D7620' oid='18A9D9750C7B4bd3803E570F532B63F8' temploid='0A6B2FC1A4784590810B6D8F2395245F' attrcatref='_0000020D2473C2E0' usage='sys' v='16000' df='hex'>
<NAME>
<TUV xml:lang='en-US'>TesterPresentFunc</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Defines the TesterPresent message for functionally addressed requests used to keep a diagnostic session active.</TUV>
</DESC>
<QUAL>CAN.TesterPresentFunc</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D6620' oid='EEAA392E2793492c8880BAC9CD4FF752' temploid='48C51BB08406428dB383652046E2F120' attrcatref='_0000020D2473BF20' usage='sys' v='20' df='dec'>
<NAME>
<TUV xml:lang='en-US'>STmin</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>(Separation Time) defines the minimum time gap between consecutive frames.Values from 0x00 to 0x7F (0 – 127) are absolute milliseconds.Values from 0xF1 to 0xF9 are even 100 micro seconds.Every other value range is reserved and should not be used.</TUV>
</DESC>
<QUAL>CAN.StMin</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D7C20' oid='A486BB6EAC3F45589992CE07BFE37AFF' temploid='5535C0ECC4F74385BEB268AF6C959410' attrcatref='_0000020D2473C2E0' usage='sys' v='0' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Blocksize</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The Blocksize parameter indicates, how many consecutive frames shall be sent in a transmission before a flow control frame is sent. The number 0 tells the sender, that no more flow controls should disrupt the sending of the remaining flow controls</TUV>
</DESC>
<QUAL>CAN.Blocksize</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D6C20' oid='7D70DAE8DB354cbd8C39F9F97E3A93BE' temploid='AE608BF1472549e0BE904D83A15582D4' attrcatref='_0000020D2473BF20' usage='sys' v='1000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Timeout As</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for transmission of frame, sender side</TUV>
</DESC>
<QUAL>CAN.TimeoutAs</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D4620' oid='C49EDB08936847f1B8FE930B333C23D5' temploid='EFCE99A5A52B47d99DCEF987DF3A7B10' attrcatref='_0000020D2473BF20' usage='sys' v='1000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Timeout Ar</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for transmission of frame, receiver side</TUV>
</DESC>
<QUAL>CAN.TimeoutAr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D6020' oid='50928B2730DC4afe8B32D0135B9ADB40' temploid='CAB50C54EB9545f38A85A4E58777B6AF' attrcatref='_0000020D2473BF20' usage='sys' v='1000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Timeout Bs</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until reception of next flow control</TUV>
</DESC>
<QUAL>CAN.TimeoutBs</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D8020' oid='696CEABD87194fbdB96A6BC6461E471D' temploid='6AA7459CF3DA4f1aA663BB7C3811CA60' attrcatref='_0000020D2473BF20' usage='sys' v='10' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Time Br</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for next transmission of flow control</TUV>
</DESC>
<QUAL>CAN.TimeBr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D4420' oid='50D9D14DA6054b69B5419243DA1D183F' temploid='C5575B04EA73449e9A15AB30619E19F7' attrcatref='_0000020D2473BF20' usage='sys' v='10' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Time Cs</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until next transmission of consecutive frame</TUV>
</DESC>
<QUAL>CAN.TimeCs</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D5C20' oid='B4932A4DA2FD428d8F6D1DF1EEAF9079' temploid='6560F131D61C416cB5FD678C7776D5A7' attrcatref='_0000020D2473BF20' usage='sys' v='1000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Timeout Cr</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until reception of next consecutive frame</TUV>
</DESC>
<QUAL>CAN.TimeoutCr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D4820' oid='D3739C318D774dcbA1D923B9D5F263C5' temploid='4EF79462693C4617B394D987AE6122CC' attrcatref='_0000020D2473C2E0' usage='sys' v='4095' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Max Length of TP Message</TUV>
</NAME>
<QUAL>CAN.MaxLengthTpMessage</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D5020' oid='1FADEAC0DF0240c9B1B28878F097183C' temploid='C255AA9A58AC4fbdA74FD391614BC428' attrcatref='_0000020D2473C2E0' usage='sys' v='500000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Baudrate</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Bus Speed of the used transport media. Caution, the Bus Speed has to be set identical in all ECUs connected to one subnet.</TUV>
</DESC>
<QUAL>CAN.Baudrate</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D6E20' oid='7C4449CC0DDF4ec185FCAE9AF16777CD' temploid='8114C6FE9DFE40caAFF9E1710BD5280D' attrcatref='_0000020D2473C2E0' usage='sys' v='0' df='hex'>
<NAME>
<TUV xml:lang='en-US'>CANFrameFillerByte</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Fill byte used for filling CAN frames to eight byte length.</TUV>
</DESC>
<QUAL>CAN.CANFrameFillerByte</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D24930AA0' oid='BB852A37A6974c2eB773BC61231C8F1E' temploid='4AF233532E5B4aa98B23A6A6E08E6EB4' attrcatref='_0000020D2473C2E0' usage='sys' v='1' sort='id'>
<NAME>
<TUV xml:lang='en-US'>FillerByteHandling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enables use of fill bytes; if "true", fill bytes are used, otherwise DLC may be smaller than 8.</TUV>
</DESC>
<QUAL>CAN.FillerByteHandling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>false</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>true</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D24931260' oid='AFA5437A3ECC4623BCAAA533134E9993' temploid='9140ACFA97F74f9bBF3A4EF8A0E67725' attrcatref='_0000020D2473D360' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>FlexRay (ISO10681 TP)</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Communication interface for FlexRay protocol. Based on the specification: ISO10681-2 "Road vehicles —  Communication on FlexRay —  Part 2: Communication Layer services". ISO document date 2009-10-23.</TUV>
</DESC>
<QUAL>FlexRay_ISO</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>not supported</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>supported</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D249304D0' oid='3CEC50BB296B476594860AA004F7416D' temploid='33CEBBC4A37D42e9864330AA45647A0B' attrcatref='_0000020D2473C2E0' usage='admin' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>BusType</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Type of transport media.</TUV>
</DESC>
<QUAL>FlexRay_ISO.BusType</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>FlexRay</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D248D4C20' oid='87B8551C8CB44ea3B6C2FA844A7FC190' temploid='70F7576FC2FE4822A04B83E47CD338B4' attrcatref='_0000020D2473BF20' usage='admin' v='150' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Timeout for the client to wait after the successful transmission of a request message for the start of incoming response messages. In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>FlexRay_ISO.CP_P2Max</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D6420' oid='52756887DB004683B8B0387F7024E52D' temploid='8EC2C7175F2B4d818E1022DACCFA3FDB' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Performance requirement for the server to start with the response message after the reception of a request message. In UDS this is the timeout for the default session.The tester will also require the P2Server timeout, since in UDS service "DiagnosticSessionControl" returns the P2Server and P2*Server timeouts – the tester has to calculate the offset manually and has to add it to the returned P2Server and P2*Server timeouts.</TUV>
</DESC>
<QUAL>FlexRay_ISO.CP_P2Max_Ecu</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D4E20' oid='9166219FE70B49f3AFC5CEF29CA44AF6' temploid='BD3EFAECE9A94870820237F2681570F1' attrcatref='_0000020D2473BF20' usage='admin' v='2000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2ExClient</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enhanced timeout for the client to wait after the reception of a negative response message with response code 78 hex for the start of incoming response messages. In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>FlexRay_ISO.CP_P2Star</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D6220' oid='36AC408AFF6F49c5A4A19CE94F478834' temploid='84FB63DDF991405eB1962B6090375E6B' attrcatref='_0000020D2473BF20' usage='admin' v='1950' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2ExServer</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Performance requirement for the server to start with the response message after the transmission of a negative response message with response code 78 hex (enhanced response timing). In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>FlexRay_ISO.CP_P2Star_Ecu</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D5420' oid='2063A15CE53945ebB63A198966351F9D' temploid='029A47066FD647c4B72C2B560271E12B' attrcatref='_0000020D2473BF20' usage='admin' v='4000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>S3Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time between functionally addressed Tester Present request messages transmitted by the client to keep a diagnostic session other than the defaultSession active in multiple servers (functional communication) or maximum time between physically transmitted request messages to a single server (physical communication).</TUV>
</DESC>
<QUAL>FlexRay_ISO.CP_TesterPresentTime</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D5620' oid='8593B77A9DE845538671D81C8599ABE3' temploid='1AC44FF91BD849239B3ACE94FFE11CA7' attrcatref='_0000020D2473BF20' usage='admin' v='5000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>S3Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for the server to keep a diagnostic session other than the defaultSession active while not receiving any diagnostic request message.</TUV>
</DESC>
<QUAL>FlexRay_ISO.CP_TesterPresentTime_Ecu</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D5820' oid='6F361F7769014236B7683B826B88D95B' temploid='C8C69719A4CA4aa1A9738A21A869B818' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P3ClientPhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Minimum time for the client to wait after the successful transmission of a physically addressed request message with no response required before it can transmit the next physically addressed request message. Minimum value = P2Server.</TUV>
</DESC>
<QUAL>FlexRay_ISO.CP_P3Phys</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D6820' oid='BA90E211C41D4ee7BDF21B63EFBE2C87' temploid='0CC842BEF51C4983B9947BE3CD20A1D4' attrcatref='_0000020D2473C2E0' usage='admin' v='17476' df='hex'>
<NAME>
<TUV xml:lang='en-US'>EcuAddress</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Defines the ecu address. Messages addressed to the ecu will contain this address as target address within the message header.</TUV>
</DESC>
<QUAL>FlexRay_ISO.EcuAddress</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D5A20' oid='DF418FABD4404c72B51706E4A980986D' temploid='AD158C32DBBE489c8196B940E0E4A4AA' attrcatref='_0000020D2473C2E0' usage='admin' v='4660' df='hex'>
<NAME>
<TUV xml:lang='en-US'>TesterAddress</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Defines the tester address. Messages addressed to the ecu will contain this address as source address within the message header.</TUV>
</DESC>
<QUAL>FlexRay_ISO.TesterAddress</QUAL>
</UNSDEF>
<CSTRDEF id='_0000020D1DF21CD0' oid='F76D1FE7CD19492a88728E693ED28C55' temploid='B200EA78E1A549afB8DC166BABC13460' attrcatref='_0000020D2473C2E0' usage='admin'>
<NAME>
<TUV xml:lang='en-US'>PDUListReqPhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the physical request channel. Can be single PDU or multiple Slots (comma separated list).</TUV>
</DESC>
<QUAL>FlexRay_ISO.PDUListReqPhys</QUAL>
<COMMONSTRING></COMMONSTRING>
</CSTRDEF>
<CSTRDEF id='_0000020D1DF21EB0' oid='ED77E405011A41228E9569A16CFC5D31' temploid='68D2120C1F60404f87CE55D4C6EB2938' attrcatref='_0000020D2473C2E0' usage='admin'>
<NAME>
<TUV xml:lang='en-US'>PDUListRes</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the physical response channel. Can be single PDU or multiple Slots (comma separated list).</TUV>
</DESC>
<QUAL>FlexRay_ISO.PDUListRes</QUAL>
<COMMONSTRING></COMMONSTRING>
</CSTRDEF>
<ENUMDEF id='_0000020D24931450' oid='AC4B3A883D8743038CD4A66BBAAF4B58' temploid='8DB2F87211044f2d9CA09184F740E135' attrcatref='_0000020D2473C2E0' usage='admin' v='1' sort='id'>
<NAME>
<TUV xml:lang='en-US'>FillerByteHandling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enables or disables frame padding (0 = false, 1 = true).</TUV>
</DESC>
<QUAL>FlexRay_ISO.FillerByteHandling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>false</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>true</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D248D6A20' oid='51FC6FD818B7474c8B3A248E38F2F501' temploid='E73A82A5B97D4b2784C2B26F242B63DD' attrcatref='_0000020D2473C2E0' usage='admin' v='0' df='hex'>
<NAME>
<TUV xml:lang='en-US'>FrFrameFillerByte</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Byte value that is used for frame padding, if padding is enabled.</TUV>
</DESC>
<QUAL>FlexRay_ISO.FrFrameFillerByte</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D24931FF0' oid='06D78CF765B14fdf8C73CA0622F876FD' temploid='DCBABFB31D604897B9E4DE06F05118BC' attrcatref='_0000020D2473C2E0' usage='admin' v='1' sort='id'>
<NAME>
<TUV xml:lang='en-US'>AutoP2Handling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Support ISO14229 DiagnosticSessionControl service's influence on P2 (P2Client and P2ExClient) timings. Depending on the configured value, the timings will be updated or not (0 = Disabled, 1 = Enabled).</TUV>
</DESC>
<QUAL>FlexRay_ISO.AutoP2Handling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Disabled</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Enabled</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D249308B0' oid='78C2718535D547b5B31578FD712CBE89' temploid='F205B2F7B6DB4872A68F383931A14842' attrcatref='_0000020D2473C2E0' usage='admin' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>RC21Handling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Repetition mode in case of KWP2000 negative response code 0x21 busy – repeat request (0 = Disabled, 1 = Enabled, 2 = EnabledUnlimited).</TUV>
</DESC>
<QUAL>FlexRay_ISO.RC21Handling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Disabled</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Enabled</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>EnabledUnlimited</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D248D7220' oid='0688B9CF17884d499ED4FF82B7567B08' temploid='C2B4D1A56E6640d3AF4AC098B0361A70' attrcatref='_0000020D2473BF20' usage='admin' v='10' df='dec'>
<NAME>
<TUV xml:lang='en-US'>RC21RequestTime</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time between negative response with response code 0x21 and the retransmission of the same request. If P3ClientPhys is greater than RC21RequestTime, the time delay prior to the retransmission of the same request will be P3ClientPhys.</TUV>
</DESC>
<QUAL>FlexRay_ISO.RC21RequestTime</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D248D7420' oid='BF3EDF357FD84d1880F7ABE790B1A403' temploid='D6DA064AAF6D4c86A788F905E4B8424E' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>RC21CompletionTimeout</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time period the tester accepts repeated negative responses with response code 0x21 and repeats the same request. Timer is started after reception of first negative response.</TUV>
</DESC>
<QUAL>FlexRay_ISO.RC21CompletionTimeout</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D24931640' oid='AA580EF425454d23AF653A86A2700091' temploid='94BF4EDEC6954ddb9384F01136C1ADBF' attrcatref='_0000020D2473C2E0' usage='admin' v='2' sort='id'>
<NAME>
<TUV xml:lang='en-US'>RC78Handling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Handling of 0x7F XX 0x78 ResponseTimeout and 0x78 repetitions (0 = Disabled, 1 = Enabled, 2 = EnabledUnlimited).</TUV>
</DESC>
<QUAL>FlexRay_ISO.RC78Handling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Disabled</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Enabled</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>EnabledUnlimited</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D2CFC7C80' oid='8E0AF230B13E4722B4E53F888D118DA3' temploid='2BF78B811A324c1c8044F4CE5BFA9A27' attrcatref='_0000020D2473BF20' usage='admin' v='30000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>RC78CompletionTimeout</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time period the tester accepts repeated negative responses with response code 0x78 and waits for a positive response further on.</TUV>
</DESC>
<QUAL>FlexRay_ISO.RC78CompletionTimeout</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC4680' oid='96DB1B9180944db2B76BD6BE7851DD4F' temploid='1EEFB143154F46cbAC228B655D0E3465' attrcatref='_0000020D2473BF20' usage='admin' v='125' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeoutAr</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for transmission of frame, receiver side.</TUV>
</DESC>
<QUAL>FlexRay_ISO.TimeoutAr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC5880' oid='B6766E24F0EC4914A1490B4A5F59A09D' temploid='D1E091DCEA58401d8E785E4F95701AB6' attrcatref='_0000020D2473BF20' usage='admin' v='125' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeoutAs</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for transmission of frame, sender side.</TUV>
</DESC>
<QUAL>FlexRay_ISO.TimeoutAs</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC4280' oid='6D07C6672DE3417d8EC828FE261AC466' temploid='354CF428AFD94482B926762C57741C16' attrcatref='_0000020D2473BF20' usage='admin' v='0' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeBr</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for next transmission of flow control.</TUV>
</DESC>
<QUAL>FlexRay_ISO.TimeBr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC4480' oid='DFCD7BE651C940a6BBFD2C989A69935B' temploid='84D28D8C58874cc5B0B574605077DE69' attrcatref='_0000020D2473BF20' usage='admin' v='150' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeoutBs</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until reception of next flow control.</TUV>
</DESC>
<QUAL>FlexRay_ISO.TimeoutBs</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC6080' oid='D9A1032222F34658B30D75AA51151BAC' temploid='A04A9E86B2B94caaA91E5C6795BD6737' attrcatref='_0000020D2473BF20' usage='admin' v='150' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeoutCr</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until reception of next consecutive frame.</TUV>
</DESC>
<QUAL>FlexRay_ISO.TimeoutCr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC4080' oid='8C86373FB1834c169B3459059D448634' temploid='837ABFA51F67400f9881644424C1C754' attrcatref='_0000020D2473BF20' usage='admin' v='25' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeCs</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until next transmission of consecutive frame.</TUV>
</DESC>
<QUAL>FlexRay_ISO.TimeCs</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D24931A20' oid='B336CEAD79F44c2aA88CA8207553E603' temploid='9DF031080C154b54AECE6D726B3D6AC0' attrcatref='_0000020D2473C2E0' usage='admin' v='3' sort='id'>
<NAME>
<TUV xml:lang='en-US'>TransportProtocolType</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the used FlexRay Transport Protocol Type (0 = Autosar2x, 1 = Autosar30, 2 = BMW, 3 = ISO10681).</TUV>
</DESC>
<QUAL>FlexRay_ISO.TransportProtocolType</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Autosar2x</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Autosar30</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>BMW</TUV>
</ETAG>
<ETAG v='3'>
<TUV xml:lang='en-US'>ISO10681</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D24931C10' oid='BA631DB0C78147d5A40F0A4A6A518161' temploid='521A0E12921B4ff7A6DB76FDC897E063' attrcatref='_0000020D2473C2E0' usage='admin' v='2' sort='id'>
<NAME>
<TUV xml:lang='en-US'>ConnectionModePhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the Connection Mode for physical requests (1 = UnAckUnicast, 2 = AckUnicast, 3 = AckRetryUnicast).</TUV>
</DESC>
<QUAL>FlexRay_ISO.ConnectionModePhys</QUAL>
<ETAG v='1'>
<TUV xml:lang='en-US'>UnAckUnicast</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>AckUnicast</TUV>
</ETAG>
<ETAG v='3'>
<TUV xml:lang='en-US'>AckRetryUnicast</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D2CFC7880' oid='9A3932E8951447769495E7F254A379A7' temploid='4A9E565D49D9477aAEBEF8E627CCF9BE' attrcatref='_0000020D2473C2E0' usage='admin' v='0' df='dec'>
<NAME>
<TUV xml:lang='en-US'>BufferSize</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The  maximum  number  of  data  bytes  the  receiver  allows  the  sender  to  send  via  CFs, before  waiting  for  an  authorization  to  continue  transmission  of  the  following  data  bytes  via further CFs.</TUV>
</DESC>
<QUAL>FlexRay_ISO.BufferSize</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC4880' oid='1BB7DAA8B2714dfb93E5BBBC5EBBA112' temploid='7C4DBA11629147e59A9B8E78043FED9B' attrcatref='_0000020D2473C2E0' usage='admin' v='0' df='dec'>
<NAME>
<TUV xml:lang='en-US'>BandwidthControl</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>By means of the BandwithControl (BC) parameter, the receiver reports its receiving performance level to the sender, i.e. the maximum bandwidth it can receive. The BC parameter is a one byte value.</TUV>
</DESC>
<QUAL>FlexRay_ISO.BandwidthControl</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D245F2110' oid='7FAEC06A8B5C40ceA26856E085F8607E' temploid='32A3C96F7AA34c39B4C850C47F9F71BF' attrcatref='_0000020D2473D360' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>FlexRay (Autosar2x TP)</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Communication interface for FlexRay protocol. Based on the Autosar2x specific transport protocol.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>not supported</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>supported</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D245F0DB0' oid='99D3AE47858347df887DD4C532DD661C' temploid='BD9E41A1968E4e3f9C8E6AF913209C6A' attrcatref='_0000020D2473C2E0' usage='admin' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>BusType</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Type of transport media.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.BusType</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>FlexRay</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D2CFC7280' oid='0B46BB3D2AB44a8fB66FB51ACEDAA01D' temploid='6E4757A190FE46889462329EED761870' attrcatref='_0000020D2473BF20' usage='admin' v='150' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Timeout for the client to wait after the successful transmission of a request message for the start of incoming response messages. In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.CP_P2Max</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC7480' oid='55D89E1D4C3743098A54D8410CCCFC5E' temploid='A9ED920EA45940219DB2B66C77B4F05C' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Performance requirement for the server to start with the response message after the reception of a request message. In UDS this is the timeout for the default session.The tester will also require the P2Server timeout, since in UDS service "DiagnosticSessionControl" returns the P2Server and P2*Server timeouts – the tester has to calculate the offset manually and has to add it to the returned P2Server and P2*Server timeouts.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.CP_P2Max_Ecu</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC6A80' oid='E2D1568717514f6cAEF2511F47A85864' temploid='D878BEE8217540be9FDE0C6832D71C8D' attrcatref='_0000020D2473BF20' usage='admin' v='2000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2ExClient</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enhanced timeout for the client to wait after the reception of a negative response message with response code 78 hex for the start of incoming response messages. In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.CP_P2Star</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC7680' oid='32F30408E5774c3cB188617285F7A7A3' temploid='632B7BC788384317809CC3DD68315FCE' attrcatref='_0000020D2473BF20' usage='admin' v='1950' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2ExServer</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Performance requirement for the server to start with the response message after the transmission of a negative response message with response code 78 hex (enhanced response timing). In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.CP_P2Star_Ecu</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC7A80' oid='06476D90AF084805957A23F96221BFF5' temploid='C930B65DE35E47d096EDC6DE61AD39EC' attrcatref='_0000020D2473BF20' usage='admin' v='4000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>S3Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time between functionally addressed Tester Present request messages transmitted by the client to keep a diagnostic session other than the defaultSession active in multiple servers (functional communication) or maximum time between physically transmitted request messages to a single server (physical communication).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.CP_TesterPresentTime</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC6C80' oid='84AAAB22E4AD4a8dACD3A0889908535A' temploid='8883A3FDEDED4235B593497A15AC0730' attrcatref='_0000020D2473BF20' usage='admin' v='5000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>S3Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for the server to keep a diagnostic session other than the defaultSession active while not receiving any diagnostic request message.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.CP_TesterPresentTime_Ecu</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC4A80' oid='7C15EE8486CC4b04A5FDD5855779825C' temploid='5F401A1E9BA14b49B8109428C9BF85C5' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P3ClientPhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Minimum time for the client to wait after the successful transmission of a physically addressed request message with no response required before it can transmit the next physically addressed request message. Minimum value = P2Server.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.CP_P3Phys</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC4E80' oid='80548409A4384b11886B14CBB8EFC873' temploid='54151AAD5ABF403eA5CFE80E63E403A0' attrcatref='_0000020D2473C2E0' usage='admin' v='17476' df='hex'>
<NAME>
<TUV xml:lang='en-US'>EcuAddress</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Defines the ecu address. Messages addressed to the ecu will contain this address as target address within the message header.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.EcuAddress</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC5280' oid='67EB3BEC08154b7080B1C474A8688A89' temploid='1CB805F360DB4ed08C26C250C312F0C4' attrcatref='_0000020D2473C2E0' usage='admin' v='4660' df='hex'>
<NAME>
<TUV xml:lang='en-US'>TesterAddress</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Defines the tester address. Messages addressed to the ecu will contain this address as source address within the message header.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.TesterAddress</QUAL>
</UNSDEF>
<CSTRDEF id='_0000020D1DF22630' oid='D8B432F6210442a6982B6987365775C4' temploid='B4D69B1B1E494dedA5872F3FDC9D1F45' attrcatref='_0000020D2473C2E0' usage='admin'>
<NAME>
<TUV xml:lang='en-US'>PDUListReqPhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the physical request channel. Can be single PDU or multiple Slots (comma separated list).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.PDUListReqPhys</QUAL>
<COMMONSTRING></COMMONSTRING>
</CSTRDEF>
<CSTRDEF id='_0000020D1DF22810' oid='5256BB8212054e869C48581456E364CE' temploid='11C421A54B224f67951029A4F6F71E73' attrcatref='_0000020D2473C2E0' usage='admin'>
<NAME>
<TUV xml:lang='en-US'>PDUListRes</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the physical response channel. Can be single PDU or multiple Slots (comma separated list).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.PDUListRes</QUAL>
<COMMONSTRING></COMMONSTRING>
</CSTRDEF>
<ENUMDEF id='_0000020D245F1B40' oid='99AF68B286C24546A3975EF03E508CC8' temploid='D4EC4ACB48D24f59B4F5C5641D6E1700' attrcatref='_0000020D2473C2E0' usage='admin' v='1' sort='id'>
<NAME>
<TUV xml:lang='en-US'>FillerByteHandling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enables or disables frame padding (0 = false, 1 = true).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.FillerByteHandling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>false</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>true</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D2CFC5C80' oid='B3EA06AF13854e9cB0817F3B09DB3980' temploid='934EF1A297C84a508F66D02197BA834A' attrcatref='_0000020D2473C2E0' usage='admin' v='0' df='hex'>
<NAME>
<TUV xml:lang='en-US'>FrFrameFillerByte</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Byte value that is used for frame padding, if padding is enabled.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.FrFrameFillerByte</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D245F24F0' oid='0C4C2CB2238B4476B000E51A417CF77F' temploid='6500441CC5244372BEFFA6C9B0806174' attrcatref='_0000020D2473C2E0' usage='admin' v='1' sort='id'>
<NAME>
<TUV xml:lang='en-US'>AutoP2Handling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Support ISO14229 DiagnosticSessionControl service's influence on P2 (P2Client and P2ExClient) timings. Depending on the configured value, the timings will be updated or not (0 = Disabled, 1 = Enabled).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.AutoP2Handling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Disabled</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Enabled</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D245F1570' oid='2E00467514314802A36EF83CBD087C67' temploid='5FDD91F76BA94698A59E5B061D122E44' attrcatref='_0000020D2473C2E0' usage='admin' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>RC21Handling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Repetition mode in case of KWP2000 negative response code 0x21 busy – repeat request (0 = Disabled, 1 = Enabled, 2 = EnabledUnlimited).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.RC21Handling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Disabled</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Enabled</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>EnabledUnlimited</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D2CFC5A80' oid='1C265D26363A44bf846A10D124A2A5AB' temploid='6D6BC198D69E4456A13AA2D596C01E06' attrcatref='_0000020D2473BF20' usage='admin' v='10' df='dec'>
<NAME>
<TUV xml:lang='en-US'>RC21RequestTime</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time between negative response with response code 0x21 and the retransmission of the same request. If P3ClientPhys is greater than RC21RequestTime, the time delay prior to the retransmission of the same request will be P3ClientPhys.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.RC21RequestTime</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC5080' oid='5F7C4F0D1893446e96E3A004ABB410A7' temploid='E825BA4142BB406aB7653A854A89FEE8' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>RC21CompletionTimeout</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time period the tester accepts repeated negative responses with response code 0x21 and repeats the same request. Timer is started after reception of first negative response.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.RC21CompletionTimeout</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D245F1F20' oid='4552E8376E614b238B7AA90D60116D4E' temploid='2F76FB3BE60E4938821E4D5B2A752F8A' attrcatref='_0000020D2473C2E0' usage='admin' v='2' sort='id'>
<NAME>
<TUV xml:lang='en-US'>RC78Handling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Handling of 0x7F XX 0x78 ResponseTimeout and 0x78 repetitions (0 = Disabled, 1 = Enabled, 2 = EnabledUnlimited).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.RC78Handling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Disabled</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Enabled</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>EnabledUnlimited</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D2CFC5E80' oid='2A3B1B3604D94b9fABCBD7ACFC36B3C9' temploid='16820517C2424af29D328640DD8C2838' attrcatref='_0000020D2473BF20' usage='admin' v='30000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>RC78CompletionTimeout</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time period the tester accepts repeated negative responses with response code 0x78 and waits for a positive response further on.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.RC78CompletionTimeout</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC4C80' oid='F50EDDDE82C2477aAB9ED2ECCC10A1DA' temploid='396C69C6664E440b88F1FF12D34AC5FF' attrcatref='_0000020D2473BF20' usage='admin' v='125' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeoutAr</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for transmission of frame, receiver side.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.TimeoutAr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC5480' oid='189E7301EF2444428D60A4603FE84F63' temploid='B7AA8A765BE54a93BB4F88F62A396D21' attrcatref='_0000020D2473BF20' usage='admin' v='125' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeoutAs</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for transmission of frame, sender side.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.TimeoutAs</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC5680' oid='4BAADEB52F9C4d1c883BD9CC1036DB2B' temploid='E54498A726E44f8896AC346FDF1CA3F6' attrcatref='_0000020D2473BF20' usage='admin' v='0' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeBr</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for next transmission of flow control.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.TimeBr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC6280' oid='DF7B0CD206A84f37AB387EBF82CE6784' temploid='8BDA3F5AE07B41ca8E81E2D1B9CF7CD2' attrcatref='_0000020D2473BF20' usage='admin' v='150' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeoutBs</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until reception of next flow control.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.TimeoutBs</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC6880' oid='1B7A3D1E17AC4b9aA3EED3F53E4D80FF' temploid='349ED325C93545cb9E3304432EBA13F4' attrcatref='_0000020D2473BF20' usage='admin' v='150' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeoutCr</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until reception of next consecutive frame.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.TimeoutCr</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC6E80' oid='F4B418470BEF4cb5B6CA17D6B5C86281' temploid='42BCD1EF169741e1B69634578F8676A2' attrcatref='_0000020D2473BF20' usage='admin' v='25' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TimeCs</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until next transmission of consecutive frame.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.TimeCs</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D245F1950' oid='065FE285A57D44f18786EAC17262C9B8' temploid='334FB71DB7E84bc4854CF227622DFF90' attrcatref='_0000020D2473C2E0' usage='admin' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>TransportProtocolType</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the used FlexRay Transport Protocol Type (0 = Autosar2x, 1 = Autosar30, 2 = BMW, 3 = ISO10681).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.TransportProtocolType</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Autosar2x</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Autosar30</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>BMW</TUV>
</ETAG>
<ETAG v='3'>
<TUV xml:lang='en-US'>ISO10681</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D245F1D30' oid='E9C992C1442E4528887115A598CE23BA' temploid='1F6DB6AC8D814fd8B9D59214FD564134' attrcatref='_0000020D2473C2E0' usage='admin' v='2' sort='id'>
<NAME>
<TUV xml:lang='en-US'>ConnectionModePhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the Connection Mode for physical requests (1 = UnAckUnicast, 2 = AckUnicast, 3 = AckRetryUnicast).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.ConnectionModePhys</QUAL>
<ETAG v='1'>
<TUV xml:lang='en-US'>UnAckUnicast</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>AckUnicast</TUV>
</ETAG>
<ETAG v='3'>
<TUV xml:lang='en-US'>AckRetryUnicast</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D245F0FA0' oid='73D847BCBE1B481c983072F02A814E43' temploid='97CA9B86154847e28BACB06B8C42E8DF' attrcatref='_0000020D2473C2E0' usage='admin' v='3' sort='id'>
<NAME>
<TUV xml:lang='en-US'>MessageLength</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Message Length of physically addressed request (= message length mode (Autosar FlexRay TP 2.1, 10.2.3): ISO = 1 (up to 4095 bytes, do not use extended frame types), ISO6 = 2 (as ISO, but payload length is limited to 6 bytes), L16M = 3 (up to 2^24-1 bytes, E4 frames not allowed), L4G = 4 (up to 2^32-1 bytes, all frames allowed).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.MessageLengthPhys</QUAL>
<ETAG v='1'>
<TUV xml:lang='en-US'>ISO</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>ISO6</TUV>
</ETAG>
<ETAG v='3'>
<TUV xml:lang='en-US'>L16M</TUV>
</ETAG>
<ETAG v='4'>
<TUV xml:lang='en-US'>L4G</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D2CFC6480' oid='F50E0BA4549A4fa2967CF51FF635D744' temploid='82B4B7AA84234210BF00938160962744' attrcatref='_0000020D2473C2E0' usage='admin' v='0' df='dec'>
<NAME>
<TUV xml:lang='en-US'>BlockSize</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The Block Size parameter indicates, how many consecutive frames shall be sent in a transmission before a flow control frame is sent. The number 0 tells the sender, that no more flow controls should disrupt the sending of the remaining flow controls.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.BlockSize</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2CFC6680' oid='10C8DAC91B464445A4A25C6EA085D932' temploid='E6DBF459978849418B19F9B66037DAD5' attrcatref='_0000020D2473C2E0' usage='admin' v='20' df='dec'>
<NAME>
<TUV xml:lang='en-US'>SeparationTime</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Separation Time defines the minimum time gap between consecutive frames. Values from 0x00 to 0x7F (0 – 127) are absolute milliseconds. Values from 0xF1 to 0xF9 are even 100 micro seconds. Every other value range is reserved and should not be used.</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.StMin</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D245F26E0' oid='FAC00346E69D4fecA1CB9B1F31AB3F71' temploid='74872A8635B64042BB1F8CC5A66F0FD7' attrcatref='_0000020D2473C2E0' usage='admin' v='2' sort='id'>
<NAME>
<TUV xml:lang='en-US'>AddressTypePhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Describes the number of address bytes used within the header of physically addressed messages (1 = 1 byte addresses, 2 = 2 byte addresses).</TUV>
</DESC>
<QUAL>FlexRay_Autosar2x.AddressTypePhys</QUAL>
<ETAG v='1'>
<TUV xml:lang='en-US'>1</TUV>
</ETAG>
<ETAG v='2'>
<TUV xml:lang='en-US'>2</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D245F1190' oid='C24176A00F454d298D85D141D17A2B73' temploid='159A0A9188CF468b9F6BA502EF9DAB58' attrcatref='_0000020D2473D360' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>DoIP (ISO13400)</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Communication interface for Diagnostics over IP (DoIP) protocol. Based on the specification: ISO13400-2 "Road vehicles — Diagnostic communication over Internet Protocol (DoIP) — Part 2: Network and transport layer requirements and services". ISO document date 2009-11-28</TUV>
</DESC>
<QUAL>DoIP</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>not supported</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>supported</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D245F28D0' oid='3B6508A506E04b2c997920E86339A538' temploid='B38EDB0580FB4609B65ECB55B1333A51' attrcatref='_0000020D2473C2E0' usage='admin' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>BusType</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Type of transport media</TUV>
</DESC>
<QUAL>DoIP.BusType</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>DoIP</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_0000020D2D327870' oid='8430BE09AC2749d1B60CEA171A706416' temploid='64AAE2A2C298473f83B3C841BE6809B6' attrcatref='_0000020D2473C2E0' usage='admin' v='515' df='hex'>
<NAME>
<TUV xml:lang='en-US'>LogicalSourceAddress</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The source address of the test equipment. This is the logical address as defined by the OEM.</TUV>
</DESC>
<QUAL>DoIP.CP_LogicalSourceAddress</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D327270' oid='2ACC8C72D6054c9281DC6229D0B50A9A' temploid='33D032673E8845a3B887940B2E751E5F' attrcatref='_0000020D2473C2E0' usage='admin' v='512' df='hex'>
<NAME>
<TUV xml:lang='en-US'>LogicalTargetAddress</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The target address of the ECU for physical communication. This is the logical address as defined by the OEM.</TUV>
</DESC>
<QUAL>DoIP.CP_LogicalTargetAddress</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D326870' oid='F0C220834E2344769791E218D16418A9' temploid='A2161964364640eb80547794239BE8C4' attrcatref='_0000020D2473C2E0' usage='admin' v='13400' df='dec'>
<NAME>
<TUV xml:lang='en-US'>TCPDataPort</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>TCP port number for DoIP entity to listen on and also used by the test equipment to establish connection to the DoIP entity.</TUV>
</DESC>
<QUAL>DoIP.CP_TCPDataPort</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D328E70' oid='65A0B3F8C9DD40658A50832897C67E8A' temploid='828115845BD341d6852CDE73A8F42A7E' attrcatref='_0000020D2473C2E0' usage='admin' v='13400' df='dec'>
<NAME>
<TUV xml:lang='en-US'>UDPVehicleListen</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Used for vehicle information requests and control commands from the test equipment to the vehicle's DoIP entities. This port is used as destination port in UDP packets sent by the test equipment.</TUV>
</DESC>
<QUAL>DoIP.CP_UDPVehiclePort</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D329870' oid='D151BE1E0D9143a595F3B244AAEA4708' temploid='32EAC65284ED4b668089E0E3D5492772' attrcatref='_0000020D2473C2E0' usage='admin' v='13401' df='dec'>
<NAME>
<TUV xml:lang='en-US'>UDPTestEquipmentPort</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Used for UDP packets sent by the DoIP entities without having received a request (e.g. Vehicle Identification Announcement message). This port is used as destination port in these UDP packets.</TUV>
</DESC>
<QUAL>DoIP.CP_UDPTestEquipmentPort</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D329070' oid='B2D421EFCC7C4ca6AB421A52509E0D0D' temploid='7356A6B26C3E45fbA9F49C08EFF34C2D' attrcatref='_0000020D2473BF20' usage='admin' v='150' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Timeout for the client to wait after the successful transmission of a request message for the start of incoming response messages. In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>DoIP.P2Client</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D328070' oid='CFAAA76706CC41eeB4820761B91219CC' temploid='82DDD264E6F148e2AC89CBCDA211CCF2' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Performance requirement for the server to start with the response message after the reception of a request message. In UDS this is the timeout for the default session.The tester will also require the P2Server timeout, since in UDS service "DiagnosticSessionControl" returns the P2Server and P2*Server timeouts – the tester has to calculate the offset manually and has to add it to the returned P2Server and P2*Server timeouts.</TUV>
</DESC>
<QUAL>DoIP.P2Server</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D327C70' oid='B472E1A9606A471aA7D0EAFE005FC263' temploid='4CD137B543694fb9A216A6ED3EBDE94A' attrcatref='_0000020D2473BF20' usage='admin' v='2000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2ExClient</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enhanced timeout for the client to wait after the reception of a negative response message with response code 78 hex for the start of incoming response messages. In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>DoIP.P2ExClient</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D326A70' oid='72959FA497EA4c0bA30B9F51C21D0C24' temploid='B105F2E2FF0845d793A2AEDCFBCC9642' attrcatref='_0000020D2473BF20' usage='admin' v='1950' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P2ExServer</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Performance requirement for the server to start with the response message after the transmission of a negative response message with response code 78 hex (enhanced response timing). In UDS this is the timeout for the default session.</TUV>
</DESC>
<QUAL>DoIP.P2ExServer</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D327E70' oid='01C7ADB7801A43738D6421AA7D964B21' temploid='60A817FD9ABE4d08872ECB7C91AD6BA3' attrcatref='_0000020D2473BF20' usage='admin' v='4000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>S3Client</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time between functionally addressed Tester Present request messages transmitted by the client to keep a diagnostic session other than the defaultSession active in multiple servers (functional communication) or maximum time between physically transmitted request messages to a single server (physical communication).</TUV>
</DESC>
<QUAL>DoIP.CP_TesterPresentTime</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D329A70' oid='2B439B3DF4D2420f81A4CEBA49360075' temploid='1DE8B5C208E649c7B134712613A218DD' attrcatref='_0000020D2473BF20' usage='admin' v='5000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>S3Server</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for the server to keep a diagnostic session other than the defaultSession active while not receiving any diagnostic request message.</TUV>
</DESC>
<QUAL>DoIP.CP_TesterPresentTime_Ecu</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D328A70' oid='CD851A1085D04ccc8D5F8A17EC4E1FD8' temploid='6D2639FDEA574fbfB75A6DE710D3454C' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
<NAME>
<TUV xml:lang='en-US'>P3ClientPhys</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Minimum time for the client to wait after the successful transmission of a physically addressed request message with no response required before it can transmit the next physically addressed request message. Minimum value = P2Server.</TUV>
</DESC>
<QUAL>DoIP.CP_P3Phys</QUAL>
</UNSDEF>
<ENUMDEF id='_0000020D2472A660' oid='A7085C96728C4d8aA9EC764F47FE2DCA' temploid='6EF520FB4D0F4063B1A8DF0E69763B30' attrcatref='_0000020D2473C2E0' usage='admin' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>RC21Handling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Repetition mode in case of negative response code 0x21 (busy – repeat request)</TUV>
</DESC>
<QUAL>CAN.RC21Handling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Disabled</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>Enabled</TUV>
</ETAG>
<ETAG v='2'>
