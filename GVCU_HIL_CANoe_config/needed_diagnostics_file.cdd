<RECORD id='_0000020D35A979D0' oid='3BD713C58B264384B05EE70E193E488C' v='12753799'>
<TEXT>
<TUV xml:lang='en-US'>

 1/Level_A:Lost Communication With GVCU
</TUV>
</TEXT>
<TRRECORDITEM idref='_0000020D2471F0C0'>
<TEXT>
<TUV xml:lang='en-US'>1/2s does not receive any packet from the node</TUV>
</TEXT>
</TRRECORDITEM>
<TRRECORDITEM idref='_0000020D2471E7C0'>
<TEXT>
<TUV xml:lang='en-US'>1/ Receives the packet for 2 consecutive seconds</TUV>
</TEXT>
