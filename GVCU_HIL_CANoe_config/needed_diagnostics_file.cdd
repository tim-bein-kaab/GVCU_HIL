<NAME>
<TUV xml:lang='en-US'>RC21RequestTime</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Time between negative response with response code 0x21 and the retransmission of the same request. If P3ClientPhys is greater than RC21RequestTime, the time delay prior to the retransmission of the same request will be P3ClientPhys.</TUV>
</DESC>
<QUAL>CAN.RC21RequestTime</QUAL>
</UNSDEF>
<UNSDEF id='_0000020D2D329270' oid='230C2368AF344bc98AD9A0D3BBF59043' temploid='0A341948E43544d887C13C5D324C0C9E' attrcatref='_0000020D2473BF20' usage='admin' v='100' df='dec'>
