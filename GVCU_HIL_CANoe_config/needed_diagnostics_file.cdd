<NAME>
<TUV xml:lang='en-US'>Addressing Scheme</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Addressing Scheme used for physical requests and responses.</TUV>
</DESC>
<QUAL>CAN.AddrScheme</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Normal</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_0000020D245B6F90' oid='C4DFC3493DFA4d78B7A0F0600052F753' temploid='21854EDB6291471bA024632AD6A7688E' attrcatref='_0000020D2473C2E0' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>CAN-ID Type</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>CAN-ID Type used for physical requests and responses</TUV>
</DESC>
<QUAL>CAN.CanIdType</QUAL>
<ETAG v='0'>
