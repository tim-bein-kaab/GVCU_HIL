CM_ SG_ 493 e2e_alive_counter "Alive counter for E2E";
CM_ SG_ 493 lat_accel_v "VALID signal";
CM_ SG_ 493 long_accel_v "VALID signal";
CM_ SG_ 493 long_accel "Longitudal acceleration (X-axis)";
