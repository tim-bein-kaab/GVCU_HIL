CM_ BU_ DDC "KW damper control unit";
CM_ BU_ EPSA "DIAS Electric Power Steering";
CM_ BU_ GVCU "Vehicle Control Module";
CM_ BO_ 485 "steering angle and rotation speed as well as status bits from power steering";
CM_ SG_ 485 e2e_checksum "CRC check value according to specification E2E";
CM_ SG_ 485 e2e_alive_counter "Alive counter for E2E";
CM_ SG_ 485 ag_failr_sts "failure status of internal EPS sensors";
CM_ SG_ 485 failr_sts "failure / degration status of entire EPS";
CM_ SG_ 485 haptic_feedback_sens_sts "status of haptic feedback function";
CM_ SG_ 485 calibration_sts "calibration status of steering angle sensor";
CM_ SG_ 485 hands_off_steer_sts "status of hands off detection function";
CM_ SG_ 485 eps_perf_mod_fb "feedback of performance mode - to verfiy EPS is working in the correct mode";
CM_ BO_ 486 "steering torque as well inhibit bits for ADAS";
CM_ SG_ 486 e2e_checksum "CRC check value according to specification E2E";
CM_ SG_ 486 e2e_alive_counter "Alive counter for E2E";
CM_ SG_ 486 steer_whl_snsr_v "valid bit for both, steering angle and steering rotation speed";
CM_ SG_ 486 steer_tq "current steering torque";
CM_ SG_ 486 steer_whl_ag "steering wheel angle";
CM_ SG_ 486 steer_whl_rot_spd "steering wheel rotation speed";
CM_ BO_ 488 "vehicle speed";
CM_ SG_ 488 e2e_checksum "CRC check value according to specification E2E";
CM_ SG_ 488 e2e_alive_counter "Alive counter for E2E";
CM_ SG_ 488 vehicle_speed_v "Vehicle speed by GVCU valid parameter";
CM_ SG_ 488 vehicle_speed "Vehicle speed by GVCU";
CM_ BO_ 490 "vehicle information";
CM_ SG_ 490 e2e_checksum "CRC check value according to specification E2E";
CM_ SG_ 490 e2e_alive_counter "Alive counter for E2E";
CM_ SG_ 490 accelerator_pedal_position_v "Acceleration pedal position in % valid";
CM_ SG_ 490 accelerator_pedal_state "Status of accelerator pedal";
CM_ SG_ 490 brk_pressure_v "Status of accelerator pedal valid signal";
CM_ SG_ 490 accelerator_pedal_position "Acceleration pedal position in %";
CM_ SG_ 490 eps_perf_mod_req "sets the performance mode of the vehicle";
CM_ SG_ 490 drv_mod "sets the drive mode of the vehicle";
CM_ SG_ 490 haptic_feedback_sens_req "request to shake the steering wheel";
CM_ SG_ 490 launch_control_active "Indicates if launch control is active";
CM_ SG_ 490 ddc_perf_mod_req "Active Suspension Mode request";
CM_ BO_ 491 "steering angle and rotation speed send out by GVCU";
CM_ SG_ 491 e2e_checksum "CRC check value according to specification E2E";
CM_ SG_ 491 e2e_alive_counter "Alive counter for E2E";
CM_ BO_ 493 "Accelerometer(CoG): X, Y";
